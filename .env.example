# =============================================================================
# NORT — .env.example
# Copy this to .env (backend) and apps/dashboard/.env.local (frontend).
# Never commit real values. This file IS committed as a reference.
# =============================================================================

# ════════════════════════════════════════════════════════════════════
#  BACKEND  (root .env — loaded by FastAPI / uvicorn)
# ════════════════════════════════════════════════════════════════════

# ─── OpenRouter (LLM) ────────────────────────────────────────────────────────
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=            # Primary key — SynthesisAgent + SentimentAgent
OPENROUTER_API_KEY_FALLBACK=   # Fallback key used on 429 rate-limit
OPENCLAW_TOKEN=                # Alias for OPENROUTER_API_KEY_FALLBACK

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=                  # postgresql://user:pass@host/db?sslmode=require

# ─── Privy Auth (backend JWT verification) ───────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WEBHOOK_SECRET=          # whsec_... for Svix webhook signature verification
NEXT_PUBLIC_PRIVY_APP_ID=      # Same as PRIVY_APP_ID — read by auth.py check
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=

# ─── Tavily Search ───────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Backend internals ───────────────────────────────────────────────────────
BACKEND_BASE_URL=http://127.0.0.1:8000   # Self-reference for bot→backend bridge
AGENT_HMAC_SECRET=                        # Change before going live

# ─── x402 / Premium payments ─────────────────────────────────────────────────
X402_REQUIRED_AMOUNT=0.10
X402_ASSET=USDC
X402_CHAIN=Base
NORT_TREASURY_ADDRESS=                    # Your Base-chain wallet that receives payments
DEMO_ENABLED=true                         # Set false in production to disable proof=demo

# ─── Pretium (M-Pesa on-ramp / off-ramp) ─────────────────────────────────────
PRETIUM_API_KEY=
PRETIUM_SECRET_KEY=
PRETIUM_CHECKOUT_KEY=
PRETIUM_BASE_URL=https://api.pretium.africa
PRETIUM_WEBHOOK_BASE_URL=                 # e.g. https://nort-backend.onrender.com
PRETIUM_CHAIN=BASE
PRETIUM_ASSET=USDC
PRETIUM_FIAT_CURRENCY=KES
PRETIUM_MOBILE_NETWORK=Safaricom

# ─── Optional external APIs ──────────────────────────────────────────────────
POLYMARKET_API_URL=https://gamma-api.polymarket.com
LIFI_API_KEY=
EXCHANGERATE_API_KEY=

# ════════════════════════════════════════════════════════════════════
#  FRONTEND  (apps/dashboard/.env.local — loaded by Next.js)
#  On Vercel: set these in the Environment Variables panel
# ════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_PRIVY_APP_ID=      # Same as PRIVY_APP_ID above
NEXT_PUBLIC_API_URL=           # Backend URL: http://localhost:8000 (dev) or https://nort-backend.onrender.com (prod)
NEXT_PUBLIC_URL=               # Public dashboard URL (e.g. https://nort.vercel.app)
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Server-side only (Next.js API routes / SSR — never exposed to browser)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WEBHOOK_SECRET=
OPENCLAW_TOKEN=
DATABASE_URL=                  # Only needed if Next.js API routes query Neon directly
